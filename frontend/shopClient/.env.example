# Скопируйте в .env или .env.local и укажите свой адрес бэкенда
# Переменные с префиксом VITE_ доступны во фронтенде

# Базовый URL API (с суффиксом /api)
VITE_API_BASE_URL=http://localhost:8080/api

# Заглушки для товаров без фото (необязательно)
VITE_PLACEHOLDER_IMAGE_URL=https://via.placeholder.com/400x300?text=Нет+фото
VITE_PLACEHOLDER_IMAGE_SMALL_URL=https://via.placeholder.com/150?text=Нет+фото
